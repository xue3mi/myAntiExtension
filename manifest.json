{
  "manifest_version": 3,
  "name": "Web Annotator",
  "version": "1.0",
  "description": "Annotate any web page with tools and layers, like Photoshop.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "Toggle Web Annotator"
  },
  "background": {
    "service_worker": "background.js"
  }
}
